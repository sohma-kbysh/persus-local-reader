.DS_Store
__pycache__/
*.pyc

# Local macOS launchers generated for one machine.
*.app/
!Perseus Local Reader.app/
!Perseus Local Reader.app/**
scripts/*.applescript
scripts/*.jxa
!scripts/open_reader_app.jxa
!scripts/stop_reader_app.jxa
!scripts/update_reader_app.jxa
.developer/scripts/*.applescript
.developer/scripts/*.jxa
!.developer/scripts/open_reader_app.jxa
!.developer/scripts/stop_reader_app.jxa
!.developer/scripts/update_reader_app.jxa

# Works downloaded by the user (Apology ships with the repo).
.developer/app/data/texts/*
!.developer/app/data/texts/tlg0059.tlg002.json

# Runtime state.
data/build/
.developer/data/build/

# Download/cache artifacts that are not needed to use the published reader.
data/vendor/
.developer/data/vendor/
.developer/swift-app/.build/
